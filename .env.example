# Geocoding (server) + Maps JavaScript (client): same key is fine if both APIs are enabled on it.
# GOOGLE_API_URL=https://maps.googleapis.com/maps/api/geocode/json?address=
# GOOGLE_API_KEY=

# Optional: set only if Maps JS should use a different key than GOOGLE_API_KEY.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Map ID from Google Cloud Console (Map Management). Required for advanced markers (district number pins).
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# DISTRICT_API_URL=

# Optional: OpenStates API key for state legislature members by address/lat-lng.
# OPENSTATES_API_KEY=
